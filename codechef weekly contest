## problem 3
Target Temperature
#include <bits/stdc++.h>
using namespace std;
void solve()
{
	int n;
	i(n);
	vll nums(n);
	iv(nums);
	ll maxi = *max_element(nums.begin(), nums.end());
	umap <ll, int> hash;
	for(ll num : nums){
	    hash[num]++;
	}
	for(auto it : hash){
	    if(it.second != 1){
	        if(it.first != maxi){
	            print("No");
	            return;
	        }
	    }
	}
	print("Yes");
}

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(NULL);
	int t = 1;
	cin >> t;
	while (t--)
	{
		solve();
	}
}

## problem 4 
Recurrence Reachability

#include <bits/stdc++.h>
using namespace std;

int modpow(int a,int b) {
	int ans = 1;
	while(b) {
		if(b % 2 == 1) {
			ans = (ans * a) % mod;
		}
		a = (a * a) % mod;
		b >>= 1;
	}
	return ans;
}
 
//--main functions--//

void solve() {
    long long N, M;
    cin >> N >> M;

    if (M >= 1 && M < N) {
        cout << M << " " << M + 1 << "\n";
        return;
    }

    if (M > 1 && M <= N) {
        cout << M - 1 << " " << M << "\n";
        return;
    }
    for (long long pw = 4; pw <= 2e18; pw *= 2) {
        long long s = pw - 1;           

        long long d_max = (M - 1) / s;

        long long d_min;
        if (s == 1) {
            continue;
        }
        long long gap = M - N; 
        if (gap <= 0) {
            d_min = 1;
        } else {
            d_min = (gap + (s - 2)) / (s - 1); 
        }

        d_min = max(d_min, 1LL);

        if (d_min <= d_max) {
            long long d = d_min;   
            long long x = M - d * s;
            long long y = x + d;
            if (x >= 1 && y <= N && x < y) {
                cout << x << " " << y << "\n";
                return;
            }
        }

        if (s >= M) break;
    }

    cout << -1 << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T;
    cin >> T;
    while (T--) {
        solve();
    }
    return 0;
}

