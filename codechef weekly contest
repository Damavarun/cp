## problem 1 
Imperfect Numbers

#include <bits/stdc++.h>
using namespace std;

bool imperfect(int x){
    if(x <= 0) return false;
    bool by2 = (x % 2 == 0);
    bool by5 = (x % 5 == 0);
    return by2 ^ by5;   // XOR
}

int main(){
    int T;
    cin >> T;
    
    while(T--){
        int N;
        cin >> N;
        
        for(int d = 0; d <= 200; d++){
            
            if(imperfect(N - d)){
                cout << d << endl;
                break;
            }
            
            if(imperfect(N + d)){
                cout << d << endl;
                break;
            }
        }
    }
}

