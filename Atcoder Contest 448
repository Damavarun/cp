int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n,traget;
    cin>>n>>traget;

    vector<int>arr(n);
    vector<int>ans;

    for(int i=0;i<n;i++){
        cin>>arr[i];

        if(arr[i]<traget){
            ans.push_back(1);
            traget=arr[i];
        }
        else{
            ans.push_back(0);
        }

    }

    for(int i=0;i<n;i++){
        cout<<ans[i]<<endl;
    }


}


