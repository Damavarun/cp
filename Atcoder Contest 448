// D - Integer-duplicated Path 

//Problem Description -- > link https://atcoder.jp/contests/abc448/tasks/abc448_d


#include<bits/stdc++.h>
using namespace std;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int N;
    cin>>N;

    vector<long long>A(N+1);

    for(int i=1;i<=N;i++){
        cin>>A[i];
    }

    vector<vector<int>>adjls(N+1);

    for(int i=0;i<N-1;i++){
        int u,v;
        cin>>u>>v;
        adjls[u].push_back(v);
        adjls[v].push_back(u);

    }

    vector<string>ans(N+1);

    map<long long,int>freq;
    
    int dupcnt =0;

    queue<int>q;
    vector<int> parent(N+1,-1);

    q.push(1);

    while(!q.empty()){
        int node =q.front();
        q.pop();

        freq[A[node]]++;


        if(freq[A[node]]==2){
            dupcnt++;
        }
        if(dupcnt>0){
            ans[node] = "Yes";
        }
        else{
            ans[node] = "No";
        }

        for(auto it:adjls[node]){
            if(it==parent[node]){
                continue;
            }
            parent[it]=node;
            q.push(it);
        }
    }

    for(int i=1;i<=N;i++){
        cout << ans[i] << "\n";
    }
}
