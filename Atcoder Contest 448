// C - Except and Min

//Problem Description -- > link https://atcoder.jp/contests/abc448/tasks/abc448_c

#include<bits/stdc++.h>
using namespace std;

int main(){
    int N,Q;

    cin>>N>>Q;

    vector<int>A(N+1);

    for(int i=1;i<=N;i++){
        cin>>A[i];
    }
    
    vector<pair<int,int>>V;

    for(int i=1;i<=N;i++){
        V.push_back({A[i],i});
    }

    sort(V.begin(),V.end());

    while(Q--){
        int K;
        cin>>K;
       
        
        set<int>remove;

        for(int i=1;i<=K;i++){
            int x;
            cin>>x;
             remove.insert(x);
        }

        for(auto it:V){
            if(!remove.count(it.second)){
                cout<<it.first<<endl;
                break;
            }
        }
    }

    return 0;
}


