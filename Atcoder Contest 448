// B - Pepper Addiction  

//Problem Description -- > link https://atcoder.jp/contests/abc448/tasks/abc448_b

#include<bits/stdc++.h>
using namespace std;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n,m;
    cin>>n>>m;

    vector<int>C(m+1);

    for(int i=1;i<=m;i++){
        cin>>C[i];
    }

    vector<int>demand(m+1,0);
    for(int i=0;i<n;i++){
        int A,B;

        cin>>A>>B;

        demand[A]+=B;

    }

    long long ans = 0;

    for(int i=1;i<=m;i++){
        ans+=min(demand[i],C[i]);
    }

    cout<<ans<<endl;
}



